    "@vue/test-utils": "^2.4.11",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.6.0",
    "eslint-config-biome": "^2.1.3",
    "eslint-plugin-vue": "^10.9.2",
    "jsdom": "^29.1.1",
    "lefthook": "^2.1.9",
    "tailwindcss": "^4.3.2",
    "typescript": "~6.0.3",
    "vite": "^8.1.0",
    "vitest": "^4.1.9",
